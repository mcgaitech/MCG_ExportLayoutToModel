<UserControl x:Class="MCGCadPlugin.Views.DetailDesign.Controls.PropertiesPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FF353535">

    <UserControl.Resources>
        <SolidColorBrush x:Key="LabelBrush" Color="#FF999999"/>
        <SolidColorBrush x:Key="ValueBrush" Color="#FFEEEEEE"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF0078D4"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="8,6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Properties grid -->
            <RowDefinition Height="Auto"/>  <!-- Profile dropdown -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" x:Name="HeaderText" Text="Properties"
                   Foreground="{StaticResource ValueBrush}" FontFamily="Segoe UI"
                   FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>

        <!-- Properties grid -->
        <Grid Grid.Row="1" x:Name="PropsGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" Foreground="{StaticResource LabelBrush}" FontSize="10" Margin="0,2"/>
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PropName" Foreground="{StaticResource ValueBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,2"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="GUID:" Foreground="{StaticResource LabelBrush}" FontSize="10" Margin="0,2"/>
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PropGuid" Foreground="{StaticResource ValueBrush}" FontFamily="Consolas" FontSize="9" Margin="0,2"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Type:" Foreground="{StaticResource LabelBrush}" FontSize="10" Margin="0,2"/>
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PropType" Foreground="{StaticResource ValueBrush}" FontSize="10" Margin="0,2"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Layer:" Foreground="{StaticResource LabelBrush}" FontSize="10" Margin="0,2"/>
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="PropLayer" Foreground="{StaticResource ValueBrush}" FontSize="10" Margin="0,2"/>

            <TextBlock Grid.Row="4" Grid.Column="0" x:Name="ThkLabel" Text="Thickness:" Foreground="{StaticResource LabelBrush}" FontSize="10" Margin="0,2"/>
            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,2">
                <TextBox x:Name="PropThickness" Width="50" Background="#FF3C3C3C" Foreground="White"
                         BorderBrush="#FF555555" FontFamily="Consolas" FontSize="10" Padding="2,1"/>
                <TextBlock Text=" mm" Foreground="{StaticResource LabelBrush}" FontSize="10" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Row="5" Grid.Column="0" x:Name="WidthLabel" Text="FL Width:" Foreground="{StaticResource LabelBrush}" FontSize="10" Margin="0,2" Visibility="Collapsed"/>
            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="PropFlangeWidth" Foreground="#FF4FC3F7" FontFamily="Consolas" FontSize="10" Margin="0,2" Visibility="Collapsed"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Area:" Foreground="{StaticResource LabelBrush}" FontSize="10" Margin="0,2"/>
            <TextBlock Grid.Row="6" Grid.Column="1" x:Name="PropArea" Foreground="{StaticResource ValueBrush}" FontFamily="Consolas" FontSize="10" Margin="0,2"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="Length:" Foreground="{StaticResource LabelBrush}" FontSize="10" Margin="0,2"/>
            <TextBlock Grid.Row="7" Grid.Column="1" x:Name="PropLength" Foreground="{StaticResource ValueBrush}" FontFamily="Consolas" FontSize="10" Margin="0,2"/>

            <TextBlock Grid.Row="8" Grid.Column="0" Text="Height:" Foreground="{StaticResource LabelBrush}" FontSize="10" Margin="0,2"/>
            <TextBlock Grid.Row="8" Grid.Column="1" x:Name="PropHeight" Foreground="{StaticResource ValueBrush}" FontFamily="Consolas" FontSize="10" Margin="0,2"/>

            <TextBlock Grid.Row="9" Grid.Column="0" Text="Throw:" Foreground="{StaticResource LabelBrush}" FontSize="10" Margin="0,2"/>
            <TextBlock Grid.Row="9" Grid.Column="1" x:Name="PropThrow" Foreground="#FF66BB6A" FontFamily="Consolas" FontSize="10" Margin="0,2"/>
        </Grid>

        <!-- Profile dropdown (cho Stiffener/BS) -->
        <StackPanel Grid.Row="2" x:Name="ProfilePanel" Orientation="Horizontal" Margin="0,6,0,0"
                    Visibility="Collapsed">
            <TextBlock Text="Profile:" Foreground="{StaticResource LabelBrush}" FontSize="10"
                       VerticalAlignment="Center" Width="70"/>
            <ComboBox x:Name="ProfileDropdown" Width="120" Background="#FF3C3C3C" Foreground="Black"
                      BorderBrush="#FF555555" FontFamily="Consolas" FontSize="10"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Apply" Background="{StaticResource AccentBrush}" Foreground="White"
                    BorderThickness="0" Padding="12,4" FontSize="10" Cursor="Hand"
                    Click="Apply_Click" Margin="0,0,6,0"/>
            <Button Content="Apply All Same" Background="#FF444444" Foreground="White"
                    BorderThickness="0" Padding="12,4" FontSize="10" Cursor="Hand"
                    Click="ApplyAllSame_Click" Margin="0,0,6,0"/>
            <Button x:Name="BtnApplySelected" Content="Apply to Selected" Background="#FF444444"
                    Foreground="White" BorderThickness="0" Padding="12,4" FontSize="10"
                    Cursor="Hand" Click="ApplySelected_Click" Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</UserControl>
